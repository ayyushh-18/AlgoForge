{
    "compilerOptions": {
        "types": ["node"],
        "target": "es2020",
        "module": "Node16",
        "outDir": "./dist",
        "rootDir": "./src",
        "moduleResolution": "node16",
        "resolveJsonModule": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}